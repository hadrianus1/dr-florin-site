# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# PostgreSQL connection string
# Free option: https://neon.tech (no expiry on free tier)
DATABASE_URL=postgresql://user:password@host/dbname

# Admin credentials — set strong values before deploying
ADMIN_PASSWORD=change-me-to-a-strong-password
JWT_SECRET=change-me-to-a-random-32-char-string

# PORT is NOT set here locally — react-scripts (frontend) defaults to 3000,
# server.js (backend) defaults to 3001. On Render, PORT is injected automatically.
